<?xml version="1.0" ?>
<robot name="spined_dog">
  <mujoco>
    <compiler meshdir="./meshes/" balanceinertia="true" discardvisual="false" fusestatic="false"/>
  </mujoco>

  <!-- Hind Body -->
  <link name="hind_body">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.984"/>
      <inertia ixx="0.01547635" iyy="0.00747572" izz="0.02098524" 
        ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/simplify_sim_hind_body.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/simplify_sim_hind_body.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_hind_left_leg_upper" type="revolute">
    <parent link="hind_body"/>
    <child link="hind_left_leg_upper"/>
    <limit effort="1000" lower="-10" upper="10" velocity="1000"/>
    <!-- joints rotates around the y-axis -->
    <axis xyz="0 1 0"/>
    <origin rpy="0 -1.57 0" xyz="-0.033679841 0.136689830 0.000000820"/>
    <!-- pybullet simulation parameters -->
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- Hind Left Leg -->
  <link name="hind_left_leg_upper">
    <inertial>
      <origin xyz="-0.05829842 0.01014064 -0.00091992" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00011593" iyy="0.00056031" izz="0.00051694" 
        ixy="0.00000315" iyz="0.00000114" ixz="-0.00001841"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/simplify_sim_hind_left_leg_upper.stl"
          scale="0.001 0.001 0.001"/>
      </geometry>
      
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/simplify_sim_hind_left_leg_upper.stl"
          scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_hind_left_leg_lower" type="revolute">
    <parent link="hind_left_leg_upper"/>
    <child link="hind_left_leg_lower"/>
    <limit effort="1000" lower="-10" upper="10" velocity="1000"/>
    <!-- joints rotates around the y-axis -->
    <axis xyz="0 1 0"/>
    <origin rpy="0 0 0" xyz="-0.151 0.012 0.0"/>
    <!-- pybullet simulation parameters -->
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <link name="hind_left_leg_lower">
    <inertial>
      <origin xyz="-0.062232355 0 0" rpy="0 0 0"/>
      <mass value="0.035"/>
      <inertia ixx="0.00000335" iyy="0.00014425" izz="0.00014301" 
        ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/simplify_sim_hind_left_leg_lower.stl"
