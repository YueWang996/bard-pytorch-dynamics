  </link>

  <joint name="joint_hind_right_leg_lower" type="revolute">
    <parent link="hind_right_leg_upper"/>
    <child link="hind_right_leg_lower"/>
    <limit effort="1000" lower="-10" upper="10" velocity="1000"/>
    <!-- joints rotates around the y-axis -->
    <axis xyz="0 1 0"/>
    <origin rpy="0 0 0" xyz="-0.151 -0.012 0.0"/>
